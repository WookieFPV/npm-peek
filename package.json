{
	"name": "npm-peek",
	"description": "Review npm dependency upgrades with interactive version selection and browser-based HTML diffs",
	"license": "MIT",
	"type": "module",
	"version": "0.2.1",
	"files": [
		"dist",
		"template.html"
	],
	"bin": {
		"npm-peek": "dist/cli.js"
	},
	"keywords": [
		"npm",
		"dependency",
		"upgrade",
		"update",
		"diff",
		"version",
		"cli"
	],
	"main": "dist/cli.js",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/WookieFPV/npm-peek.git"
	},
	"homepage": "https://github.com/WookieFPV/npm-peek#readme",
	"bugs": {
		"url": "https://github.com/WookieFPV/npm-peek/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"build:dev": "tsup --watch --clean false",
		"changeset": "changeset",
		"lint": "bunx biome check --fix",
		"lint:CI": "bunx biome check",
		"release": "changeset publish",
		"typecheck": "tsc",
		"version-packages": "changeset version",
		"prepublishOnly": "bun run lint:CI && bun run typecheck && bun run build"
	},
	"dependencies": {
		"@inquirer/prompts": "8.3.0",
		"@rnx-kit/tools-workspaces": "0.2.3",
		"@stricli/core": "1.2.5",
		"diff2html": "3.4.55",
		"diff2html-cli": "5.2.15",
		"fast-fuzzy": "1.12.0",
		"open": "11.0.0",
		"ora": "9.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@changesets/cli": "2.30.0",
		"@types/bun": "1.3.6",
		"lefthook": "2.0.15",
		"tsup": "8.5.1",
		"typescript": "5.9.3"
	}
}
